# =========================
# WakeSafe API - Local Env
# =========================

# App
PORT=5000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Security
JWT_SECRET=replace-with-strong-secret
ML_WEBHOOK_API_KEY=replace-with-ml-webhook-key

# Database
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=wakesafe
MONGO_POOL_SIZE=5

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# CORS / Socket
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
SOCKET_IO_ORIGIN=*

# GCP / Storage
GCLOUD_PROJECT_ID=your-gcp-project-id
GCLOUD_KEY_FILE=path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCS_BUCKET=your-gcs-bucket

# AI Services
AI_SERVER_URL=http://localhost:8081
ML1_SERVICE_URL=http://localhost:8001
ML2_SERVICE_URL=http://localhost:8002
ML2_SEQUENCE_WINDOW_SIZE=20
ML_CALL_MAX_RETRIES=2
ML_CALL_RETRY_BASE_MS=400
ML_ALERT_MIN_CONFIDENCE=0.75
ML_ALERT_MIN_SEVERITY=0.7
ML_ALERT_CONSECUTIVE_FRAMES=2

# Fatigue Alerting
FATIGUE_ALERT_COOLDOWN_MS=45000
FATIGUE_ALERT_MIN_CONFIDENCE=0.6
FATIGUE_ALERT_MIN_LEVEL=0.6
SAFE_STOP_RECOMMENDATION_COOLDOWN_MS=120000

# Maps / Monitoring
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_ROUTES_API_KEY=your-google-routes-api-key
MONITORING_WEBHOOK_URL=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/spotify/callback
